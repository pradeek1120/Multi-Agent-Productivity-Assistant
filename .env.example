GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

GOOGLE_CLOUD_PROJECT=
ALLOYDB_REGION=
ALLOYDB_CLUSTER=
ALLOYDB_INSTANCE=
ALLOYDB_DATABASE=
ALLOYDB_USER=
ALLOYDB_PASSWORD=
# Use `private` for the cluster you created unless you explicitly enabled public IP.
ALLOYDB_IP_TYPE=private

# Default is the production-style Toolbox binary.
# For local experimentation you can also use:
# TOOLBOX_COMMAND=npx
TOOLBOX_COMMAND=toolbox

# Optional: use a separately deployed Toolbox service instead of starting a local stdio process.
TOOLBOX_URL=
TOOLBOX_BEARER_TOKEN=
